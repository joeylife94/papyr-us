# Example environment file for running Playwright E2E locally
# Copy this to .env.test and adjust values for your local setup
# Example (Unix): cp .env.test.example .env.test
# Example (PowerShell): Copy-Item .env.test.example .env.test
#
# NOTE: .env.test is git-ignored and MUST NOT be committed.
# CI environments should inject these values via secrets/env config.
#
# The Playwright webServer command (playwright.config.ts) sets
# ENFORCE_AUTH_WRITES=true on the command line, so all E2E write
# requests require a Bearer token. Tests obtain tokens by calling
# POST /api/auth/register in their setup.

# Environment
NODE_ENV=test
# PORT must match the E2E webServer command in playwright.config.ts (default: 5003)
PORT=5003
BASE_URL=http://localhost:5003

# Database
# Use the same shape as shown in CONTRIBUTING.md and package.json scripts
DATABASE_URL=postgresql://papyrus_user:papyrus_password_2024@localhost:5433/papyrus_db

# Optional: any other environment variables your app needs for tests
# For example:
# OPENAI_API_KEY=sk-xxx
# SESSION_SECRET=replace-with-secret

## Playwright E2E auth bootstrap
# These credentials are used by tests/global-setup.ts to create a logged-in storage state.
# The seed script creates a default user with the values below.
E2E_EMAIL=test@example.com
E2E_PASSWORD=password123

# Where to write/read the Playwright storage state file
STORAGE_STATE_PATH=tests/storageState.json

## Admin panel password used by tests (see tests/example.spec.ts)
ADMIN_PASSWORD=test-admin-password

# Feature flags needed for E2E tests
FEATURE_AUTOMATION=true
FEATURE_TEAMS=true

# Auth enforcement — set on the command line in playwright.config.ts webServer.
# Do NOT override here unless you know what you're doing.
# ENFORCE_AUTH_WRITES=true   # already set by playwright.config.ts command

# Optional: variables for docker-compose parity (uncomment if you use docker-compose for tests)
# DATABASE_USER=papyrus_user
# DATABASE_PASSWORD=papyrus_password_2024
# DATABASE_NAME=papyrus_db
