# ============================================
# Papyr.us Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# Variables marked [REQUIRED in production] must be set before deploying
# Variables marked [OPTIONAL] have sensible defaults

# ============================================
# APPLICATION SETTINGS
# ============================================

# Environment: development | production | test
NODE_ENV=development

# Server port
PORT=5001

# ============================================
# MODES & FEATURE FLAGS
# ============================================

# Papyr.us can be used like Notion in two modes:
# - team (default): collaboration-first workspace (flags default ON)
# - personal: lightweight personal knowledge base (flags default OFF)
# PAPYR_MODE=team

# Feature Flag Strategy:
#   Stable (ON by default in team mode) — thoroughly tested, safe for all users
#   In Progress (OFF by default) — functional but still being hardened; opt-in only
#   Partial (OFF by default) — limited implementation; not recommended for production
#
# Core features — Stable (ON by default in team mode):
# FEATURE_TEAMS=true
# FEATURE_ADMIN=true
# FEATURE_CALENDAR=true
# FEATURE_TEMPLATES=true
# FEATURE_NOTIFICATIONS=true
#
# Production features — configure to match your deployment stack:
# FEATURE_COLLABORATION=false    # Yjs real-time editing
# FEATURE_AI_SEARCH=false        # AI search and summarization (requires OPENAI_API_KEY)
# FEATURE_AUTOMATION=false       # Workflow automation

# ============================================
# SECURITY [REQUIRED in production]
# ============================================

# JWT Secret - MUST be a strong random string in production (min 32 chars)
# Generate with: openssl rand -base64 32
# ⚠️ Server will refuse to start in production without this
JWT_SECRET=your-jwt-secret-change-in-production

# Admin password - MUST be strong in production (min 12 chars)
# ⚠️ Server will refuse to start in production without this
ADMIN_PASSWORD=your-admin-password-change-in-production

# Comma-separated list of admin email addresses
# Users with these emails get admin role on registration/login
ADMIN_EMAILS=admin@example.com

# ============================================
# AUTHENTICATION & AUTHORIZATION
# ============================================

# Require authentication for all write operations
# Default: true in production, false in development
ENFORCE_AUTH_WRITES=false

# Allow password-based admin login (vs JWT only)
# Default: false in production, true in development
ALLOW_ADMIN_PASSWORD=true

# ============================================
# RATE LIMITING
# ============================================

# Enable rate limiting (default: true in production)
RATE_LIMIT_ENABLED=false

# Rate limit window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# Maximum requests per window (default: 60)
RATE_LIMIT_MAX=60

# ============================================
# DATABASE [REQUIRED in production]
# ============================================

# PostgreSQL connection string
DATABASE_URL=postgresql://papyrus_user:papyrus_password_2024@localhost:5433/papyrus_db

# Docker Compose database settings
POSTGRES_USER=papyrus_user
POSTGRES_PASSWORD=papyrus_password_2024
POSTGRES_DB=papyrus_db
DATABASE_USER=papyrus_user
DATABASE_PASSWORD=papyrus_password_2024
DATABASE_NAME=papyrus_db

# ============================================
# AI FEATURES [OPTIONAL]
# ============================================

# OpenAI API key for AI-powered features
# Get yours at: https://platform.openai.com/api-keys
# Features: Smart search, content generation, task extraction
OPENAI_API_KEY=

# ============================================
# OAUTH PROVIDERS [OPTIONAL]
# ============================================

# Google OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft Azure AD
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
AZURE_AD_ALLOWED_DOMAINS=  # Comma-separated list of allowed email domains

# Okta
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_DOMAIN=  # e.g., your-org.okta.com

# Auth0
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_DOMAIN=  # e.g., your-tenant.auth0.com

# Generic OIDC Provider
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_ISSUER=
OIDC_AUTHORIZATION_URL=
OIDC_TOKEN_URL=
OIDC_USERINFO_URL=
OIDC_JWKS_URI=
OIDC_SCOPES=openid,email,profile
OIDC_EMAIL_CLAIM=email
OIDC_NAME_CLAIM=name
OIDC_PROVIDER_NAME=SSO
OIDC_AUTO_CREATE_USER=true

# ============================================
# CORS & NETWORKING
# ============================================

# Comma-separated list of allowed CORS origins
CORS_ALLOWED_ORIGINS=

# Allow credentials in CORS requests
CORS_ALLOW_CREDENTIALS=false

# Server host binding (default: localhost in dev, 0.0.0.0 in production)
HOST=localhost
ALLOW_HOST_OVERRIDE=false

# Admin IP whitelist (comma-separated, empty = allow all)
ADMIN_IP_WHITELIST=

# ============================================
# COLLABORATION ENGINE (Yjs + Socket.IO)
# ============================================

# Auth requirement for collaboration
# COLLAB_REQUIRE_AUTH=1

# Persistence settings
# COLLAB_SAVE_DEBOUNCE_MS=3000
# COLLAB_SNAPSHOT_INTERVAL_MS=60000
# COLLAB_RATE_LIMIT_SAVES_PER_MIN=6

# Document lifecycle
# COLLAB_DOC_TTL_MS=300000
# COLLAB_MAX_DOCS=50

# Safety limits
# COLLAB_MAX_CLIENTS_PER_DOC=20

# Rate limits
# COLLAB_RATE_LIMIT_UPDATES_PER_SEC=200
# COLLAB_RATE_LIMIT_AWARENESS_PER_SEC=100
# COLLAB_RATE_LIMIT_DOC_CHANGES_PER_SEC=50
# COLLAB_RATE_LIMIT_CURSOR_PER_SEC=30
# COLLAB_RATE_LIMIT_TYPING_PER_SEC=20

# ============================================
# SEARCH
# ============================================

# Use PostgreSQL Full-Text Search (recommended)
SEARCH_USE_FTS=true

# ============================================
# TESTING (E2E)
# ============================================

# Test credentials for E2E tests
E2E_EMAIL=test@example.com
E2E_PASSWORD=testpassword123
E2E_DEBUG_AUTH=0

# ============================================
# MONITORING & OBSERVABILITY [OPTIONAL]
# ============================================

# Sentry DSN for error tracking and performance monitoring
# Get yours at: https://sentry.io/
# Leave empty to disable Sentry
SENTRY_DSN=

# Sentry environment name (defaults to NODE_ENV)
SENTRY_ENVIRONMENT=

# Sentry performance monitoring sample rate (0.0 to 1.0)
# 1.0 = capture all transactions, 0.1 = capture 10%
SENTRY_TRACES_SAMPLE_RATE=0.1

# Enable Prometheus metrics endpoint at /metrics (default: true)
METRICS_ENABLED=true

# ============================================
# LOGGING [OPTIONAL]
# ============================================

# Log level: error | warn | info | http | debug
# Default: debug in development, info in production
LOG_LEVEL=

# Log directory for file transports (default: logs)
LOG_DIR=logs

# ============================================
# REDIS [OPTIONAL - for horizontal scaling]
# ============================================

# Redis connection URL (takes precedence over individual settings)
# Format: redis://[:password@]host[:port][/db]
REDIS_URL=

# Or individual Redis settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=papyrus:

# Explicitly enable/disable Redis (auto-detected if REDIS_URL or REDIS_HOST is set)
# REDIS_ENABLED=true

# ============================================
# CDN & STATIC ASSETS [OPTIONAL]
# ============================================

# CDN URL for serving static assets (e.g., https://cdn.example.com)
# When set, asset URLs will be prefixed with this URL
CDN_URL=

# Static asset cache max age in seconds (default: 604800 = 1 week)
STATIC_CACHE_MAX_AGE=604800

# ============================================
# AUDIT LOGGING [OPTIONAL]
# ============================================

# Enable audit logging for user actions (default: true)
AUDIT_LOG_ENABLED=true

# Audit log buffer flush interval in ms (default: 5000)
AUDIT_LOG_FLUSH_INTERVAL=5000

# ============================================
# BACKUP [OPTIONAL - for production]
# ============================================

# Backup storage directory
BACKUP_DIR=/backups

# AWS S3 bucket for remote backup storage
BACKUP_S3_BUCKET=
BACKUP_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
